<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #f5f5f5;
    padding: 2rem 1rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  header {
    text-align: center;
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    color: #2c3e50;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #7f8c8d;
    font-size: 1.1rem;
  }

  .billing-button-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400px;
  }

  .billing-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 3rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    min-width: 280px;
  }

  .billing-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
    background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
  }

  .billing-button:active {
    transform: translateY(0);
  }

  .billing-button-icon {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .billing-button {
      padding: 1.25rem 2rem;
      font-size: 1.1rem;
      min-width: 240px;
    }
  }
</style>

<div class="container">
  <header>
    <h1>Welcome, <%= current_user.name %></h1>
    <p class="subtitle">Manage your subscription and billing</p>
  </header>

  <div class="billing-button-container">
    <%= link_to billing_dashboard_path, class: "billing-button" do %>
      <svg class="billing-button-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
      </svg>
      <span>Manage Billing</span>
    <% end %>
  </div>
</div>
