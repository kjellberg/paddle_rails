<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.6;
    color: #333;
    background: #f5f5f5;
    padding: 2rem 1rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  header {
    text-align: center;
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    color: #2c3e50;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #7f8c8d;
    font-size: 1.1rem;
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .plan-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .plan-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .plan-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 0.5rem;
  }

  .plan-description {
    color: #7f8c8d;
    margin-bottom: 1.5rem;
    min-height: 3rem;
  }

  .prices-list {
    list-style: none;
  }

  .price-item {
    padding: 1rem;
    margin-bottom: 0.75rem;
    background: #f8f9fa;
    border-radius: 8px;
    border-left: 3px solid #3498db;
  }

  .price-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .price-name {
    font-weight: 600;
    color: #2c3e50;
  }

  .price-amount {
    font-size: 1.25rem;
    font-weight: 700;
    color: #27ae60;
  }

  .price-details {
    font-size: 0.9rem;
    color: #7f8c8d;
  }

  .no-plans {
    text-align: center;
    padding: 3rem;
    color: #7f8c8d;
    background: white;
    border-radius: 12px;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .plans-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="container">
  <header>
    <h1>Welcome, <%= current_user.name %></h1>
    <p class="subtitle">Choose the perfect plan for you</p>
  </header>

  <% if @plans.any? %>
    <div class="plans-grid">
      <% @plans.each do |plan| %>
        <div class="plan-card">
          <div class="plan-name"><%= plan.name %></div>
          <% if plan.description.present? %>
            <div class="plan-description"><%= plan.description %></div>
          <% end %>

          <% if plan.prices.active.any? %>
            <ul class="prices-list">
              <% plan.prices.active.order(:unit_price).each do |price| %>
                <li class="price-item">
                  <div class="price-header">
                    <span class="price-name"><%= price.name.presence || price.description.presence || "Standard" %></span>
                    <% if price.unit_price.present? %>
                      <span class="price-amount">
                        <%= number_to_currency(price.unit_price.to_f / 100, unit: price.currency == "USD" ? "$" : price.currency == "EUR" ? "€" : price.currency) %>
                      </span>
                    <% end %>
                  </div>
                  <div class="price-details">
                    <% if price.billing_interval.present? %>
                      <%= price.billing_interval_count %> <%= price.billing_interval %><% if price.billing_interval_count > 1 %>s<% end %>
                    <% else %>
                      One-time
                    <% end %>
                    <% if price.trial_days.present? && price.trial_days > 0 %>
                      · <%= price.trial_days %> day trial
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p style="color: #7f8c8d; font-style: italic;">No prices available</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="no-plans">
      <p>No subscription plans available at the moment.</p>
      <p style="margin-top: 1rem; font-size: 0.9rem;">Please sync products from Paddle to see available plans.</p>
    </div>
  <% end %>
</div>
