<div class="relative isolate flex flex-col items-center justify-center flex-1 min-h-0 px-6 py-10 lg:px-8">
  <!-- Decorative gradient blob -->
  <div aria-hidden="true" class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl">
    <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="mx-auto aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-[0.08]"></div>
  </div>

  <!-- Header -->
  <div class="mx-auto max-w-4xl text-center">
    <h2 class="text-base/7 font-semibold text-indigo-600">Pricing</h2>
    <p class="mt-2 text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Choose your plan</p>
  </div>
  <p class="mx-auto mt-4 max-w-2xl text-pretty text-center text-base font-medium text-gray-500 sm:text-lg/8">
    Simple, transparent pricing that scales with your business. All plans include core features.
  </p>

  <% if @products.any? %>
    <%
      product_count = @products.count { |p| p.any_prices? }
      grid_cols = case product_count
                  when 1 then "lg:max-w-md lg:grid-cols-1"
                  when 2 then "lg:max-w-4xl lg:grid-cols-2"
                  when 3 then "lg:max-w-5xl lg:grid-cols-3"
                  else "lg:max-w-6xl lg:grid-cols-4"
                  end
    %>

    <div class="mx-auto mt-10 grid max-w-lg grid-cols-1 items-center gap-y-6 sm:mt-12 sm:gap-y-0 gap-x-6 <%= grid_cols %>">
      <% @products.each_with_index do |product, idx| %>
        <% next unless product.any_prices? %>
        <% featured = (idx == 1 && product_count > 1) %>
        <% currency_symbol = product.primary_currency == "EUR" ? "\u20AC" : "$" %>

        <div
          class="rounded-3xl p-8 sm:p-10 flex flex-col <%= featured ? 'relative bg-gray-900 ring-1 ring-gray-900 z-10 shadow-2xl' : 'bg-white ring-1 ring-gray-200 shadow-sm' %>"
          data-plan-card="true"
        >
          <% if featured %>
            <div class="absolute -top-4 left-0 right-0 flex justify-center">
              <span class="inline-flex items-center gap-x-1.5 rounded-full bg-indigo-500 px-3.5 py-1 text-xs font-semibold text-white shadow-sm">
                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" /></svg>
                Most popular
              </span>
            </div>
          <% end %>

          <!-- Plan name -->
          <h3 class="text-base/7 font-semibold <%= featured ? 'text-indigo-400' : 'text-indigo-600' %>"><%= product.plan&.title || product.name %></h3>

          <!-- Price -->
          <p class="mt-4 flex items-baseline gap-x-2">
            <span class="text-5xl font-semibold tracking-tight <%= featured ? 'text-white' : 'text-gray-900' %>"><%= currency_symbol %><%= product.primary_amount %></span>
            <span class="text-base <%= featured ? 'text-gray-400' : 'text-gray-500' %>">/ <%= product.primary_billing %></span>
          </p>

          <!-- Description -->
          <p class="mt-6 text-base/7 <%= featured ? 'text-gray-300' : 'text-gray-600' %>"><%= product.plan&.description || product.description.presence || "Everything you need to get started" %></p>

          <!-- Features -->
          <% if product.plan_features.any? %>
            <ul role="list" class="mt-8 space-y-3 text-sm/6 sm:mt-10 flex-1 <%= featured ? 'text-gray-300' : 'text-gray-600' %>">
              <% product.plan_features.each do |feature| %>
                <li class="flex gap-x-3">
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-6 w-5 flex-none <%= featured ? 'text-indigo-400' : 'text-indigo-600' %>"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
                  <span><%= feature %></span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="mt-8 sm:mt-10 flex-1"></div>
          <% end %>

          <!-- Billing options -->
          <% if product.multiple_prices? %>
            <div class="mt-8 sm:mt-10">
              <select
                class="block w-full rounded-md text-sm py-2.5 px-3 focus:ring-2 focus:ring-indigo-500 <%= featured ? 'bg-white/5 border-0 ring-1 ring-white/10 text-white' : 'bg-gray-50 border-0 ring-1 ring-gray-200 text-gray-900' %>"
                data-price-select="true"
              >
                <% product.price_options.each_with_index do |(price_id, label), i| %>
                  <option value="<%= price_id %>" data-price-label="<%= label %>" <%= "selected" if i.zero? %>><%= label %></option>
                <% end %>
              </select>
            </div>
          <% end %>

          <!-- CTA -->
          <%= form_with url: onboarding_checkout_path, method: :post, local: true do |f| %>
            <%= f.hidden_field :paddle_price_id, value: product.primary_price_id, data: { price_input: true } %>
            <% if featured %>
              <%= f.submit product.primary_label,
                class: "mt-8 sm:mt-10 block w-full rounded-md bg-indigo-500 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500 cursor-pointer transition-colors",
                data: { price_button: true } %>
            <% else %>
              <%= f.submit product.primary_label,
                class: "mt-8 sm:mt-10 block w-full rounded-md bg-gray-900 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-gray-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 cursor-pointer transition-colors",
                data: { price_button: true } %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20">
      <p class="text-gray-500 text-sm">No plans available at the moment.</p>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll("[data-price-select]").forEach(function(select) {
      select.addEventListener("change", function(event) {
        var option = select.selectedOptions[0];
        if (!option) return;

        var card = select.closest("[data-plan-card]");
        if (!card) return;

        var hiddenField = card.querySelector("[data-price-input]");
        var button = card.querySelector("[data-price-button]");

        if (hiddenField) hiddenField.value = option.value;
        if (button && option.dataset.priceLabel) button.value = option.dataset.priceLabel;
      });
    });
  });
</script>
