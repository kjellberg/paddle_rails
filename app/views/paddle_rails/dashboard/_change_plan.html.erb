<!-- Plan Management Section -->
<section class="mb-8 md:mb-12">
  <h2 class="text-xl font-normal text-gray-900 mb-6">Change Plan</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- Starter Plan -->
    <div class="bg-white border border-gray-200 rounded-lg p-6 hover:border-purple-400 transition-colors">
      <div class="mb-4">
        <h3 class="text-lg font-normal text-gray-900 mb-2">Starter</h3>
        <div class="mb-3">
          <span class="text-2xl font-light text-gray-900">$9</span>
          <span class="text-gray-600 text-sm">/month</span>
        </div>
        <p class="text-sm text-gray-600">Perfect for getting started</p>
      </div>
      <button class="w-full px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        Downgrade
      </button>
    </div>

    <!-- Pro Plan (Current) -->
    <div class="bg-white border-2 border-purple-500 rounded-lg p-6 relative">
      <div class="absolute top-4 right-4">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
          Current
        </span>
      </div>
      <div class="mb-4">
        <h3 class="text-lg font-normal text-gray-900 mb-2">Pro</h3>
        <div class="mb-3">
          <span class="text-2xl font-light text-gray-900">$29</span>
          <span class="text-gray-600 text-sm">/month</span>
        </div>
        <p class="text-sm text-gray-600">Perfect for small teams</p>
      </div>
      <button class="w-full px-4 py-2 bg-gray-100 text-gray-500 text-sm font-medium rounded-lg cursor-not-allowed" disabled>
        Current Plan
      </button>
    </div>

    <!-- Enterprise Plan -->
    <div class="bg-white border border-gray-200 rounded-lg p-6 hover:border-purple-400 transition-colors">
      <div class="mb-4">
        <h3 class="text-lg font-normal text-gray-900 mb-2">Enterprise</h3>
        <div class="mb-3">
          <span class="text-2xl font-light text-gray-900">$99</span>
          <span class="text-gray-600 text-sm">/month</span>
        </div>
        <p class="text-sm text-gray-600">Perfect for large organizations</p>
      </div>
      <button class="w-full px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition-colors">
        Upgrade
      </button>
    </div>
  </div>
</section>


