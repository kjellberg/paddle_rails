<!-- Payment History Section -->
<section class="mb-8 md:mb-12">
  <h2 class="text-xl font-normal text-gray-900 mb-6">Payment history</h2>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="overflow-x-auto -mx-4 md:mx-0">
      <table class="w-full min-w-[640px]">
        <thead class="bg-gray-50/50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Invoice</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% dates = [
               "Apr 14, 2026",
               "Mar 14, 2026",
               "Feb 14, 2026",
               "Jan 14, 2026"
             ] %>
          <% dates.each do |date| %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= date %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">CreatorWave Pro - Monthly</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-light text-gray-900">$29.00</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                  Paid
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <a href="#" class="text-purple-600 hover:text-purple-700 font-medium">Download</a>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>


