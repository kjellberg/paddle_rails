<!-- Current Subscription Section -->
<section class="mb-8 md:mb-12">
  <h2 class="text-xl font-normal text-gray-900 mb-6">Current subscription</h2>
  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4 gap-4">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-purple-400 to-pink-500 flex items-center justify-center flex-shrink-0">
          <span class="text-white font-light text-lg"><%= @subscription.product_initial %></span>
        </div>
        <div>
          <h3 class="text-lg font-normal text-gray-900 mb-1"><%= @subscription.product_name %></h3>
          <% if @subscription.has_price? %>
            <p class="text-gray-600 text-sm">
              <%= number_to_currency(@subscription.amount, unit: @subscription.currency_symbol) %> 
              <%= @subscription.currency %> 
              billed per <%= @subscription.interval_label %>
            </p>
          <% else %>
            <p class="text-gray-600 text-sm"><%= @subscription.price_display_text %></p>
          <% end %>
        </div>
      </div>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 self-start sm:self-auto">
        <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
        <%= @subscription.status_label %>
      </span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-5 border-t border-gray-100 mt-5">
      <div>
        <p class="text-xs text-gray-500 mb-1"><%= @subscription.billing_date_title %></p>
        <div class="flex items-center gap-2">
          <p class="text-sm font-light text-gray-900"><%= @subscription.billing_date %></p>
          <% if @subscription.subscription.scheduled_for_cancellation? %>
            <%= button_to "Don't cancel", 
                paddle_rails.revoke_subscription_cancellation_path, 
                method: :post,
                class: "text-xs font-medium text-purple-600 hover:text-purple-700 bg-purple-50 hover:bg-purple-100 px-2 py-1 rounded transition-colors duration-200" %>
          <% elsif @subscription.subscription.active? && !@subscription.subscription.canceled? %>
            <%= button_to "Cancel subscription", 
                paddle_rails.cancel_subscription_path, 
                method: :post,
                data: { turbo_confirm: "Are you sure you want to cancel your subscription?" },
                class: "text-xs font-medium text-red-600 hover:text-red-700 bg-red-50 hover:bg-red-100 px-2 py-1 rounded transition-colors duration-200" %>
          <% end %>
        </div>
      </div>
      <div>
        <p class="text-xs text-gray-500 mb-1">Amount</p>
        <p class="text-sm font-light text-gray-900">
          <%= @subscription.has_price? ? number_to_currency(@subscription.amount, unit: @subscription.currency_symbol) : "N/A" %>
        </p>
      </div>
    </div>
  </div>
</section>
