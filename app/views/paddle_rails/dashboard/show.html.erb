<div>
  <div class="flex justify-between mb-8">
    <div class="flex-1 min-w-0 mr-4">
      <h1 class="text-2xl font-semibold text-slate-900 tracking-tight">Billing & subscription</h1>
      <p class="text-sm text-slate-500 mt-1">Manage your plan, view payment history, download invoices, and update payment methods.</p>
    </div>
    <% back_path_proc = PaddleRails.configuration.customer_portal_back_path %>
    <% back_path = instance_exec(&back_path_proc) if back_path_proc %>
    <% if back_path.present? %>
      <%= link_to back_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-slate-900 text-white hover:bg-slate-800 text-sm font-medium transition-all duration-200 flex-shrink-0 shadow-sm self-center" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to app
      <% end %>
    <% end %>
  </div>

  <%= render "current_subscription" %>
  <%= render "payment_method" %>
  <%= render "change_plan" %>
  <%= render "payment_history" %>

  <!-- Trust Footer -->
  <footer class="mt-8 pt-8 border-t border-slate-200/60">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          PCI DSS compliant
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
          </svg>
          Secure payments
        </span>
      </div>
    </div>
  </footer>
</div>

<!-- script loaded here to make sure it's loaded after the page is rendered -->
<script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script type="text/javascript">
  Paddle.Environment.set("<%= PaddleRails.configuration.environment || 'sandbox' %>");
  Paddle.Initialize({
    token: "<%= PaddleRails.configuration.public_token %>",
    eventCallback: function(data) {
      if (data.name == "checkout.completed") {
        setTimeout(function() {
          window.location.href = "<%= url_for %>";
        }, 2000);
      };
    }
  });
</script>
