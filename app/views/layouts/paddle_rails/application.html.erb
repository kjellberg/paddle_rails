<!DOCTYPE html>
<html>
<head>
  <title>Paddle rails</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag "paddle_rails/application", media: "all" %>
  <%= stylesheet_link_tag "paddle_rails/tailwind", media: "all" %>

  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-weight: 300;
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="flex flex-col md:flex-row md:h-screen md:overflow-hidden">
    <!-- Sidebar - On top on mobile, fixed on left on desktop -->
    <aside class="w-full md:w-80 bg-gray-100 flex-shrink-0 flex flex-col border-b md:border-b-0 md:border-r border-gray-200">
      <div class="p-6 md:p-8 flex-1 overflow-y-auto">
        <!-- Subscription Owner Banner -->
        <% if subscription_owner %>
          <% 
            # Generate initials
            initials = ""
            if subscription_owner.respond_to?(:name) && subscription_owner.name.present?
              name_parts = subscription_owner.name.strip.split(/\s+/)
              if name_parts.length >= 2
                initials = (name_parts.first[0] + name_parts.last[0]).upcase
              elsif name_parts.length == 1
                initials = name_parts.first[0..1].upcase
              end
            elsif subscription_owner.respond_to?(:email) && subscription_owner.email.present?
              email_local = subscription_owner.email.split('@').first
              initials = email_local[0..1].upcase
            end
          %>
          <div class="mb-4">
            <!-- Name and Email -->
            <div class="flex-1 min-w-0">
              <% if subscription_owner.respond_to?(:name) && subscription_owner.name.present? %>
                <p class="text-sm font-medium text-gray-900 leading-snug truncate"><%= subscription_owner.name %></p>
                <% if subscription_owner.respond_to?(:email) %>
                  <p class="text-sm text-gray-500 leading-snug truncate mt-0.5"><%= subscription_owner.email %></p>
                <% end %>
              <% elsif subscription_owner.respond_to?(:email) %>
                <p class="text-sm font-medium text-gray-900 leading-snug truncate"><%= subscription_owner.email %></p>
              <% end %>
            </div>
          </div>
          <div class="h-px bg-gray-200/80 mb-6 md:mb-8"></div>
        <% end %>

        <!-- Main Heading -->
        <h1 class="text-xl md:text-2xl font-normal text-gray-900 mb-3 leading-tight">
          Manage your subscription and billing settings
        </h1>

        <!-- Description -->
        <p class="text-gray-600 text-sm leading-relaxed mb-6 md:mb-8">
          View payment history, download invoices, and manage subscriptions and payment methods.
        </p>

        <!-- Back Link -->
        <a href="#" class="text-gray-600 hover:text-gray-900 text-sm font-medium inline-flex items-center gap-1">
          ← Back
        </a>
      </div>
    </aside>

    <!-- Scrollable Content Area -->
    <main class="flex-1 overflow-y-auto bg-white">
      <%= yield %>
    </main>
  </div>
</body>
</html>
