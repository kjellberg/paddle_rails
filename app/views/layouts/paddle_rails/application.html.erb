<!DOCTYPE html>
<html>
<head>
  <title>Paddle rails</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag "paddle_rails/application", media: "all" %>
  <%= stylesheet_link_tag "paddle_rails/tailwind", media: "all" %>

  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-weight: 300;
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="flex flex-col md:flex-row md:h-screen md:overflow-hidden">
    <!-- Sidebar - On top on mobile, fixed on left on desktop -->
    <aside class="w-full md:w-80 bg-gray-100 flex-shrink-0 flex flex-col border-b md:border-b-0 md:border-r border-gray-200">
      <div class="p-6 md:p-8 flex-1 overflow-y-auto">
        <!-- Subscription Owner Banner -->
        <% if subscription_owner %>
          <% 
            # Generate initials
            initials = ""
            if subscription_owner.respond_to?(:name) && subscription_owner.name.present?
              name_parts = subscription_owner.name.strip.split(/\s+/)
              if name_parts.length >= 2
                initials = (name_parts.first[0] + name_parts.last[0]).upcase
              elsif name_parts.length == 1
                initials = name_parts.first[0..1].upcase
              end
            elsif subscription_owner.respond_to?(:email) && subscription_owner.email.present?
              email_local = subscription_owner.email.split('@').first
              initials = email_local[0..1].upcase
            end
          %>
          <div class="mb-4">
            <!-- Name and Email -->
            <div class="flex-1 min-w-0">
              <% if subscription_owner.respond_to?(:name) && subscription_owner.name.present? %>
                <p class="text-sm font-medium text-gray-900 leading-snug truncate"><%= subscription_owner.name %></p>
                <% if subscription_owner.respond_to?(:email) %>
                  <p class="text-sm text-gray-500 leading-snug truncate mt-0.5"><%= subscription_owner.email %></p>
                <% end %>
              <% elsif subscription_owner.respond_to?(:email) %>
                <p class="text-sm font-medium text-gray-900 leading-snug truncate"><%= subscription_owner.email %></p>
              <% end %>
            </div>
          </div>
          <div class="h-px bg-gray-200/80 mb-6 md:mb-8"></div>
        <% end %>

        <!-- Main Heading -->
        <h1 class="text-xl md:text-2xl font-normal text-gray-900 mb-3 leading-tight">
          Manage your subscription and billing settings
        </h1>

        <!-- Description -->
        <p class="text-gray-600 text-sm leading-relaxed mb-6 md:mb-8">
          View payment history, download invoices, and manage subscriptions and payment methods.
        </p>

        <!-- Back Link -->
        <% back_path_proc = PaddleRails.configuration.customer_portal_back_path %>
        <% back_path = instance_exec(&back_path_proc) if back_path_proc %>
        <% if back_path.present? %>
          <%= link_to back_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium inline-flex items-center gap-1" do %>
            ← Back
          <% end %>
        <% end %>
      </div>
    </aside>

    <!-- Scrollable Content Area -->
    <main class="flex-1 overflow-y-auto bg-white">
      <!-- Trust Header -->
      <div class="bg-gradient-to-r from-slate-50 to-slate-100 border-b border-slate-200/60">
        <div class="max-w-6xl mx-auto px-4 md:px-8 py-3 flex items-center justify-between">
          <div class="flex items-center gap-6 text-xs text-slate-600">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
              </svg>
              <span class="font-medium">Secure connection</span>
            </span>
            <span class="hidden sm:flex items-center gap-1.5">
              <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>256-bit SSL encrypted</span>
            </span>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span>Powered by</span>
            <span class="font-semibold text-slate-700">Paddle</span>
          </div>
        </div>
      </div>

      <!-- Flash Notifications -->
      <% if flash[:notice] || flash[:alert] %>
        <div class="px-4 md:px-8 pt-4 max-w-6xl mx-auto">
          <% if flash[:notice] %>
            <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg mb-4" role="alert">
              <p class="text-sm font-medium"><%= raw flash[:notice] %></p>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-4" role="alert">
              <p class="text-sm font-medium"><%= raw flash[:alert] %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>
</body>
</html>
