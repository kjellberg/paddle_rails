<!DOCTYPE html>
<html>
<head>
  <title>Paddle rails</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag "paddle_rails/application", media: "all" %>
  <%= stylesheet_link_tag "paddle_rails/tailwind", media: "all" %>

  <style>
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-weight: 300;
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="flex flex-col md:flex-row md:h-screen md:overflow-hidden">
    <!-- Sidebar - On top on mobile, fixed on left on desktop -->
    <aside class="w-full md:w-80 bg-gray-100 flex-shrink-0 flex flex-col border-b md:border-b-0 md:border-r border-gray-200">
      <div class="p-6 md:p-8 flex-1 overflow-y-auto">
        <!-- Profile/Store Name -->
        <div class="mb-6 md:mb-8">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-400 to-pink-500 flex items-center justify-center text-white font-semibold text-sm">
              JS
            </div>
            <span class="font-light text-gray-900">Jojo's Store</span>
          </div>
        </div>

        <!-- Main Heading -->
        <h1 class="text-xl md:text-2xl font-normal text-gray-900 mb-3 leading-tight">
          Manage your subscription and billing settings
        </h1>

        <!-- Description -->
        <p class="text-gray-600 text-sm leading-relaxed mb-6 md:mb-8">
          View payment history, download invoices, and manage subscriptions and payment methods.
        </p>

        <!-- Back Link -->
        <a href="#" class="text-gray-600 hover:text-gray-900 text-sm font-medium inline-flex items-center gap-1">
          ← Back
        </a>
      </div>
    </aside>

    <!-- Scrollable Content Area -->
    <main class="flex-1 overflow-y-auto bg-white">
      <%= yield %>
    </main>
  </div>
</body>
</html>
